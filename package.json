{
  "name": "api-automation-framework",
  "version": "1.0.0",
  "description": "Scalable REST API automation framework in TypeScript",
  "private": true,
  "dependencies": {
    "@faker-js/faker": "^10.4.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.0",
    "typescript": "^6.0.3",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.8.0",
    "allure-commandline": "^2.41.0",
    "allure-playwright": "^3.8.0",
    "prettier": "^3.8.3"
  },
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:dev": "cross-env TEST_ENV=dev playwright test",
    "test:staging": "cross-env TEST_ENV=staging playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report",
    "report:allure": "allure generate ./allure-results --clean -o ./allure-report && allure open ./allure-report",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"*/.{ts,json,md}\"",
    "typecheck": "tsc --noEmit"
  }
}
